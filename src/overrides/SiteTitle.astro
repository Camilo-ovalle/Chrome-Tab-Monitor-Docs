---
const { siteTitleHref, siteTitle } = Astro.locals.starlightRoute
---

<a href={siteTitleHref} class="site-title">
  <span class="title-text">{siteTitle}</span>
</a>

<style>
  .site-title {
    display: flex;
    align-items: center;
    margin-right: 2rem;
    margin-left: 1rem;
    color: inherit;
    text-decoration: none;
  }

  .title-text {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }
</style>
